# Smart Traffic Control runtime configuration
# Copy this file to .env and adjust values for your environment.

# Primary YOLO model (vehicle + ambulance)
MODEL_PATH=new.pt

# Accident YOLO model
ACCIDENT_MODEL_PATH=models/accident_model.pt
ACCIDENT_CONF_THRESHOLD=0.6
ACCIDENT_FRAME_SKIP=5

# Camera inputs (comma-separated)
CAMERA_URLS=http://127.0.0.1:8080/video
FRAME_WIDTH=640
FRAME_HEIGHT=480
CAMERA_RETRY_SECONDS=3

# Scheduler timings
GREEN_DURATIONS=20,15,10,10
YELLOW_DURATIONS=5
AMBULANCE_CONFIRM_SECONDS=10
INITIAL_WAIT_SECONDS=5

# Raspberry Pi communication
PI_HOST=10.10.8.138
PI_PORT=7000
SOCKET_CONNECT_TIMEOUT=3
SOCKET_SEND_TIMEOUT=2
SOCKET_RETRY_SECONDS=3

# Display
SHOW_WINDOWS=1
