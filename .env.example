# Smart Traffic Control runtime configuration
# Copy this file to .env and adjust values for your environment.

# Primary YOLO model (vehicle + ambulance)
MODEL_PATH=models/new.pt

# Inference performance
# DEVICE: auto | cpu | cuda | cuda:0
DEVICE=auto
PRIMARY_CONF_THRESHOLD=0.35
FRAME_SKIP=3

# Accident YOLO model
ACCIDENT_MODEL_PATH=models/accident_model.pt
ACCIDENT_CONF_THRESHOLD=0.6
ACCIDENT_FRAME_SKIP=5

# Camera inputs (comma-separated)
CAMERA_URLS=http://127.0.0.1:8080/video
FRAME_WIDTH=640
FRAME_HEIGHT=480
CAMERA_RETRY_SECONDS=3

# Scheduler timings
DEFAULT_GREEN_DURATIONS=20,20,20,20
DEFAULT_YELLOW_DURATIONS=5,5,5,5
DENSITY_OVERRIDE_THRESHOLD=15
TOTAL_OVERRIDE_CYCLE_TIME=80
FAIRNESS_WAIT_WEIGHT=2.0
MAX_CONSECUTIVE_PRIORITY_CYCLES=2
OVERRIDE_MIN_GREEN_SECONDS=8
OVERRIDE_MAX_GREEN_SECONDS=40
EMERGENCY_GREEN_SECONDS=15
CONTROL_MODE=cycle
CONTROL_INTERVAL_SECONDS=5
CYCLE_SLEEP_TICK_SECONDS=0.2
NORMAL_DECISION_LOCK_SECONDS=10
MIN_GREEN_TIME=5
MAX_GREEN_TIME=10
AMBULANCE_CONFIRM_SECONDS=10
AMBULANCE_DETECTION_THRESHOLD=2
AMBULANCE_MISS_THRESHOLD=3
INITIAL_WAIT_SECONDS=5
STALE_DECAY_FACTOR=0.5

# Raspberry Pi communication
PI_HOST=10.10.8.138
PI_PORT=7000
ENABLE_PI=0
SOCKET_CONNECT_TIMEOUT=3
SOCKET_SEND_TIMEOUT=2
SOCKET_RETRY_SECONDS=3

# Cloud sync (state + alert telemetry)
CLOUD_SYNC_ENABLED=0
CLOUD_SYNC_INTERVAL_SECONDS=10
CLOUD_QUEUE_SIZE=50
CLOUD_REQUEST_TIMEOUT_SECONDS=5
CLOUD_MAX_RETRIES=2
CLOUD_BACKOFF_SECONDS=0.5
# Backward-compatible alias (optional): CLOUD_RETRY_BACKOFF_SECONDS
CLOUD_API_URL=
JUNCTION_ID=J1
FULL_SIGNAL_LOGGING=0

# Display
SHOW_WINDOWS=1
